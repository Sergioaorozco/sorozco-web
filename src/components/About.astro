---
import { Image } from "astro:assets";
import Resume from "./Resume.astro";

import AstroLogo from "../assets/tools/Astrologo.svg";
import PiniaLogo from "../assets/tools/PiniaLogo.svg";
import FirebaseLogo from "../assets/tools/Firebase.svg";
import VueLogo from "../assets/tools/VueLogo.svg";
import GitLogo from "../assets/tools/GitLogo.svg";
import TailwindLogo from "../assets/tools/TailwindLogo.svg";

let Tools = [
  { name: "Astro", src: AstroLogo },
  { name: "Pinia", src: PiniaLogo },
  { name: "Firebase", src: FirebaseLogo },
  { name: "VueJs", src: VueLogo },
  { name: "Git", src: GitLogo },
  { name: "Tailwind", src: TailwindLogo },
];
---

<main class="py-12 md:py-20 wrapper">
  <section
    class="flex flex-col md:justify-between md:flex-row gap-12 lg:gap-20"
    id="linkAbout"
  >
    <article class="lg:px-0 text-slate-700 reveal md:w-1/2">
      <div class="inline-block mb-3">
        <h2
          class="text-3xl font-bold tracking-tight text-slate-800 relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-12 after:h-1 after:bg-blue-600 after:rounded-full"
        >
          About Me
        </h2>
      </div>
      <div class="mt-8 space-y-6">
        <p
          class="text-lg md:text-xl leading-relaxed text-pretty text-slate-600"
        >
          Mid-level frontend developer crafting <span
            class="text-blue-600 font-semibold"
            >user-friendly, engaging experiences</span
          > with VueJs and Astro.
        </p>
        <p
          class="text-lg md:text-xl leading-relaxed text-pretty text-slate-600"
        >
          Proficient in agile methodologies (SAFe) and teamwork, I bring a
          strong work ethic and passion for excellence to help your team achieve
          its goals.
        </p>
      </div>
      <div class="mt-8">
        <Resume />
      </div>
    </article>

    <article class="reveal md:w-1/2">
      <div class="inline-block mb-6">
        <h2
          class="text-3xl font-bold tracking-tight text-slate-800 relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-12 after:h-1 after:bg-blue-600 after:rounded-full"
        >
          Technological Stack
        </h2>
      </div>
      <div class="flex flex-wrap gap-3 mt-4">
        {
          Tools.map(({ name }) => (
            <span class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl shadow-sm hover:border-blue-500 hover:text-blue-600 hover:-translate-y-1 transition-all duration-300 cursor-default text-sm md:text-base tracking-wide">
              {name}
            </span>
          ))
        }
      </div>
    </article>
  </section>
</main>
