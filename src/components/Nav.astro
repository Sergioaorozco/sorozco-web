---
import MainIcon from "../assets/icons/MainIcon.astro";
---

<nav
  id="navSection"
  class="px-3 py-2 rounded-full bg-neutral-800/50 border border-neutral-700/30 backdrop-blur-md z-40 w-11/12 md:w-1/3 absolute top-5 left-1/2 -translate-x-1/2 transition-colors duration-300 text-white mx-auto flex justify-between items-center"
>
  <a
    href="/"
    class="size-12 p-2 rounded-full"
    aria-label="main-isotype sorozco"
  >
    <MainIcon />
  </a>
  <ul class="navLinks flex text-xl font-semibold normal-case">
    <li>
      <a class="hover:bg-black/40 rounded-full py-3 px-4" href="#linkAbout"
        >About</a
      >
    </li>
    <li>
      <a class="hover:bg-black/40 rounded-full py-3 px-4" href="#linkPortfolio"
        >Portfolio</a
      >
    </li>
  </ul>
</nav>
